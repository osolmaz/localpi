  "regexGroups": [
    {
      "id": "openclaw-local-provider-ids",
      "weight": 9,
      "patterns": [
        "\\b(vllm|ollama|lmstudio|localai)/[A-Za-z0-9._:-]+",
        "\\b(openai-compatible|openai compatible)\\b",
        "\\bhttps?://(127\\.0\\.0\\.1|localhost):[0-9]+/v1\\b"
      ]
    },
    {
      "id": "quantized-model-artifacts",
      "weight": 7,
      "patterns": [
        "\\b[A-Za-z0-9._-]+\\.(gguf|safetensors)\\b",
        "\\b(Q[2-8]_K(_[MSL])?|IQ[1-4]_[A-Z]+|AWQ|GPTQ|FP8|INT4|INT8)\\b"
      ]
    },
    {
      "id": "model-size-and-context",
      "weight": 6,
      "patterns": [
        "\\b[0-9]+(\\.[0-9]+)?[Bb]\\b",
        "\\b[0-9]+[kK] context\\b",
        "\\b[0-9]+[kK] ctx\\b",
        "\\b[0-9]+[kK] tokens?\\b"
      ]
    }
  ],
  "negativeHints": [
    "Do not tag generic gateway, docs, Discord integration, or maintainer activity unless it overlaps a keyword group and passes INTERESTS.md.",
    "Do not tag remote closed-weight provider chatter unless it affects OpenClaw local/self-hosted model usage."
  ]
}
