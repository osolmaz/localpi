{
  "schema": "openclaw-maintainer.local-model-keywords.v1",
  "description": "Machine-readable keyword groups for detecting local-model and self-hosted OpenClaw signals in maintainer workflows.",
  "tag": "local-models",
  "interestTag": "i0",
  "matchPolicy": {
    "caseSensitive": false,
    "normalizeUnicode": true,
    "matchOn": [
      "title",
      "body",
      "labels",
      "channelName",
      "threadName",
      "repoName",
      "sourceUrl"
    ],
    "recommendation": "Use these keywords as a recall filter. Apply INTERESTS.md before tagging an item as i0."
  },
  "keywordGroups": [
    {
      "id": "core-local-models",
      "weight": 10,
      "keywords": [
        "local model",
        "local models",
        "local llm",
        "local inference",
        "local ai",
        "open-weight",
        "open weight",
        "open weights",
        "self-hosted model",
