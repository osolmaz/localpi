{
  "name": "@dutifuldev/localagent",
  "version": "0.1.0",
  "description": "Pi-compatible local model launcher for OpenAI-compatible endpoints.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "localagent": "./dist/src/cli/main.js"
  },
  "files": [
    "dist/src/**",
    "docs/**",
    "examples/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage --coverage.thresholds.lines 85 --coverage.thresholds.functions 85 --coverage.thresholds.branches 85 --coverage.thresholds.statements 85",
    "dry": "slophammer-ts dry .",
    "mutate": "stryker run",
    "localagent": "tsx src/cli/main.ts",
    "check": "npm run format && npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
